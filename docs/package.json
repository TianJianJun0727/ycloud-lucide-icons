{
  "name": "@ycloud-web/icons-docs",
  "version": "1.0.0",
  "description": "",
  "homepage": "https://github.com/TianJianJun0727/ycloud-icons",
  "bugs": "https://github.com/TianJianJun0727/ycloud-icons/issues",
  "license": "ISC",
  "author": "TianJianJun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TianJianJun0727/ycloud-icons.git",
    "directory": "docs"
  },
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "docs:dev": "pnpm run /^prebuild:.*/ && vitepress dev",
    "docs:dev:no-og": "DOCS_OG=0 pnpm docs:dev",
    "docs:dev:og": "DOCS_OG=1 pnpm docs:dev",
    "docs:build": "pnpm run /^prebuild:.*/ && vitepress build",
    "docs:build:no-og": "DOCS_OG=0 pnpm docs:build",
    "docs:build:og": "DOCS_OG=1 pnpm docs:build",
    "docs:build:github-pages": "pnpm clean:generated-og && pnpm prebuild:api && DOCS_BASE=/ycloud-icons/ DOCS_OG=0 DOCS_LLMS=0 DOCS_META_CHUNK=1 pnpm generate:docs-data && NODE_OPTIONS=${NODE_OPTIONS:---max-old-space-size=12288} DOCS_BASE=/ycloud-icons/ DOCS_OG=0 DOCS_LLMS=0 DOCS_META_CHUNK=1 vitepress build && DOCS_VERCEL=0 pnpm postbuild:vercelJson",
    "docs:build:llms": "DOCS_LLMS=1 pnpm docs:build",
    "docs:preview": "vitepress preview",
    "build:docs": "vitepress build",
    "prebuild:changelog": "node ../scripts/writeChangelog.mts",
    "prebuild:iconNodes": "node ./scripts/writeIconNodes.mts",
    "prebuild:metaJson": "node ./scripts/writeIconMetaIndex.mts",
    "prebuild:releaseJson": "node ./scripts/writeReleaseMetadata.mts",
    "prebuild:categoriesJson": "node ./scripts/writeCategoriesMetadata.mts",
    "prebuild:relatedIcons": "node ./scripts/writeIconRelatedIcons.mts",
    "prebuild:iconDetails": "node ./scripts/writeIconDetails.mts",
    "prebuild:iconPopularity": "node ./scripts/writeiconPopularity.mts",
    "prebuild:brandStopwords": "node ./scripts/writeBrandStopwords.mts",
    "prebuild:fontDataUrl": "node ./scripts/writeFontDataUrl.mts",
    "clean:generated-og": "node ./scripts/cleanGeneratedOgImages.mts",
    "generate:docs-data": "pnpm prebuild:changelog && pnpm prebuild:iconNodes && pnpm prebuild:metaJson && pnpm prebuild:releaseJson && pnpm prebuild:categoriesJson && pnpm prebuild:relatedIcons && pnpm prebuild:iconDetails && pnpm prebuild:iconPopularity && pnpm prebuild:brandStopwords && pnpm prebuild:fontDataUrl",
    "postbuild:vercelJson": "node ./scripts/writeVercelOutput.mts",
    "dev": "npx nitropack dev",
    "prebuild:api": "npx nitropack prepare",
    "build:api": "npx nitropack build",
    "build": "pnpm run /^prebuild:.*/ && pnpm run build:api && pnpm run build:docs && pnpm postbuild:vercelJson",
    "preview": "node .output/server/index.mjs"
  },
  "dependencies": {
    "@floating-ui/vue": "^2.0.0",
    "@headlessui/vue": "^1.7.23",
    "@vueuse/components": "^14.0.0",
    "@vueuse/core": "^14.0.0",
    "@ycloud-web/icons": "workspace:*",
    "@ycloud-web/icons-react": "workspace:*",
    "@ycloud-web/icons-vue": "workspace:*",
    "element-to-path": "^1.2.1",
    "fuse.js": "^7.1.0",
    "jszip": "^3.10.1",
    "lodash-es": "^4.18.1",
    "motion-v": "2.3.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "sandpack-vue3": "3.1.12",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@rollup/plugin-replace": "^6.0.3",
    "@types/semver": "^7.7.1",
    "@ycloud-web/build-icons": "workspace:*",
    "@ycloud-web/helpers": "workspace:*",
    "@ycloud-web/shared": "workspace:*",
    "h3": "2.0.1-rc.22",
    "markdown-it": "^14.2.0",
    "markdown-it-container": "^4.0.0",
    "nitropack": "^2.13.4",
    "rollup-plugin-copy": "^3.5.0",
    "semver": "^7.8.5",
    "sharp": "^0.35.2",
    "shiki": "^4.3.0",
    "simple-git": "^3.36.0",
    "sitemap": "^9.0.1",
    "svg-path-commander": "^2.1.11",
    "svg-pathdata": "^9.0.0",
    "svgson": "^5.3.1",
    "vitepress": "^1.6.4",
    "vitepress-plugin-group-icons": "^1.7.5",
    "vitepress-plugin-llms": "^1.13.2"
  }
}
