{
  "name": "@ycloud-web/icons-docs",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "docs:dev": "pnpm docs:dev:no-og",
    "docs:dev:no-og": "DOCS_BASE=${DOCS_BASE:-/ycloud-icons/} DOCS_OG=0 pnpm run /^prebuild:.*/ && DOCS_BASE=${DOCS_BASE:-/ycloud-icons/} DOCS_OG=0 vitepress dev",
    "docs:dev:og": "DOCS_BASE=${DOCS_BASE:-/ycloud-icons/} DOCS_OG=1 pnpm run /^prebuild:.*/ && DOCS_BASE=${DOCS_BASE:-/ycloud-icons/} DOCS_OG=1 vitepress dev",
    "docs:build": "pnpm docs:build:no-og",
    "docs:build:no-og": "DOCS_OG=0 pnpm run /^prebuild:.*/ && DOCS_OG=0 vitepress build",
    "docs:build:og": "DOCS_OG=1 pnpm run /^prebuild:.*/ && DOCS_OG=1 vitepress build",
    "docs:preview": "vitepress preview",
    "build:docs": "vitepress build",
    "prebuild:changelog": "node ../scripts/writeChangelog.mts",
    "prebuild:iconNodes": "node ./scripts/writeIconNodes.mts",
    "prebuild:metaJson": "node ./scripts/writeIconMetaIndex.mts",
    "prebuild:releaseJson": "node ./scripts/writeReleaseMetadata.mts",
    "prebuild:categoriesJson": "node ./scripts/writeCategoriesMetadata.mts",
    "prebuild:relatedIcons": "node ./scripts/writeIconRelatedIcons.mts",
    "prebuild:iconDetails": "node ./scripts/writeIconDetails.mts",
    "prebuild:iconPopularity": "node ./scripts/writeiconPopularity.mts",
    "prebuild:brandStopwords": "node ./scripts/writeBrandStopwords.mts",
    "prebuild:fontDataUrl": "node ./scripts/writeFontDataUrl.mts",
    "postbuild:vercelJson": "node ./scripts/writeVercelOutput.mts",
    "dev": "npx nitropack dev",
    "prebuild:api": "npx nitropack prepare",
    "build:api": "npx nitropack build",
    "build": "pnpm run /^prebuild:.*/ && pnpm run build:api && pnpm run build:docs && pnpm postbuild:vercelJson",
    "preview": "node .output/server/index.mjs"
  },
  "author": "YCloud",
  "license": "ISC",
  "devDependencies": {
    "@rollup/plugin-replace": "^6.0.3",
    "@types/semver": "^7.7.1",
    "@ycloud-web/build-icons": "workspace:*",
    "@ycloud-web/helpers": "workspace:*",
    "@ycloud-web/shared": "workspace:*",
    "h3": "^1.15.9",
    "markdown-it": "^14.2.0",
    "markdown-it-container": "^4.0.0",
    "nitropack": "^2.13.4",
    "rollup-plugin-copy": "^3.5.0",
    "semver": "^7.7.3",
    "sharp": "^0.34.5",
    "shiki": "^3.15.0",
    "simple-git": "^3.36.0",
    "sitemap": "^7.1.2",
    "svg-path-commander": "^2.1.11",
    "svg-pathdata": "^6.0.3",
    "svgson": "^5.3.1",
    "vitepress": "^1.6.4",
    "vitepress-plugin-group-icons": "^1.7.5",
    "vitepress-plugin-llms": "^1.13.1"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.1.9",
    "@headlessui/vue": "^1.7.23",
    "@vueuse/components": "^14.0.0",
    "@vueuse/core": "^14.0.0",
    "@ycloud-web/icons": "workspace:*",
    "@ycloud-web/icons-react": "workspace:*",
    "@ycloud-web/icons-vue": "workspace:*",
    "element-to-path": "^1.2.1",
    "fuse.js": "^7.1.0",
    "jszip": "^3.10.1",
    "lodash-es": "^4.18.1",
    "motion-v": "1.10.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "sandpack-vue3": "3.1.12",
    "vue": "^3.5.24"
  },
  "homepage": "https://github.com/TianJianJun0727/ycloud-icons",
  "bugs": "https://github.com/TianJianJun0727/ycloud-icons/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TianJianJun0727/ycloud-icons.git",
    "directory": "docs"
  }
}
