{
  "name": "@ycloud-web/icons-react",
  "version": "0.1.12",
  "description": "A YCloud icon library package for React applications.",
  "keywords": [
    "Feather",
    "Feather Icons",
    "Font Awesome",
    "Fontawesome",
    "Icon",
    "Icons",
    "React",
    "SVG",
    "YCloud"
  ],
  "homepage": "https://tianjianjun0727.github.io/ycloud-icons/guide/react/",
  "bugs": "https://github.com/TianJianJun0727/ycloud-icons/issues",
  "license": "ISC",
  "author": "YCloud",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TianJianJun0727/ycloud-icons.git",
    "directory": "packages/icons-react"
  },
  "files": [
    "dist",
    "dynamic.js",
    "dynamic.mjs",
    "dynamic.mjs.map",
    "dynamic.d.mts",
    "dynamic.d.ts",
    "dynamicIconImports.mjs",
    "dynamicIconImports.d.ts",
    "dynamicIconImports.d.mts",
    "business.js",
    "business.js.map",
    "business.mjs",
    "business.mjs.map",
    "business.d.ts",
    "business.d.mts"
  ],
  "sideEffects": false,
  "main": "dist/cjs/ycloud-react.js",
  "module": "dist/esm/ycloud-react.mjs",
  "typings": "dist/ycloud-react.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ycloud-react.d.ts",
      "import": "./dist/esm/ycloud-react.mjs",
      "require": "./dist/cjs/ycloud-react.js",
      "default": "./dist/esm/ycloud-react.mjs"
    },
    "./business": {
      "types": "./business.d.ts",
      "import": "./business.mjs",
      "require": "./business.js",
      "default": "./business.mjs"
    },
    "./dynamic": {
      "types": "./dynamic.d.ts",
      "import": "./dynamic.mjs",
      "default": "./dynamic.mjs"
    },
    "./dynamicIconImports": {
      "types": "./dynamicIconImports.d.ts",
      "import": "./dynamicIconImports.mjs",
      "default": "./dynamicIconImports.mjs"
    },
    "./*.js": "./*.js",
    "./*.mjs": "./*.mjs",
    "./*.d.ts": "./*.d.ts",
    "./*.d.mts": "./*.d.mts",
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "pnpm clean && pnpm copy:license && pnpm build:icons && pnpm typecheck && pnpm build:bundles",
    "copy:license": "cp ../../LICENSE ./LICENSE",
    "clean": "rm -rf dist && rm -rf stats && rm -rf ./src/icons/*.ts && rm -f dynamic.{d.ts,d.mts,mts,mjs,mjs.map} && rm -f dynamicIconImports.{d.ts,d.mts,mjs,mjs.map} && rm -f business.{js,js.map,mjs,mjs.map,d.ts,d.mts}",
    "build:icons": "build-icons --output=./src --templateSrc=./scripts/exportTemplate.mts --renderUniqueKey --withAliases --withDynamicImports --separateAliasesFile --separateAliasesFileIgnore=fingerprint --aliasesFileExtension=.ts --iconFileExtension=.ts --exportFileName=index.ts && node ../../scripts/generateBusinessIconsPackage.mts react",
    "build:bundles": "NODE_OPTIONS='--require=../../scripts/useTypeScript6Register.cjs --experimental-loader=../../scripts/useTypeScript6Loader.mjs --no-warnings' rollup -c ./rollup.config.mjs",
    "typecheck": "tsc",
    "typecheck:watch": "tsc -w",
    "test": "pnpm build:icons && vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@ycloud-web/icons": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.37",
    "@vitejs/plugin-react": "^6.0.3",
    "@ycloud-web/build-icons": "workspace:*",
    "@ycloud-web/rollup-plugins": "workspace:*",
    "@ycloud-web/shared": "workspace:*",
    "jest-serializer-html": "^7.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "rollup": "^4.62.0",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-preserve-directives": "^0.4.0",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.0"
  },
  "peerDependencies": {
    "react": "^16.5.1 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "amdName": "ycloud-react"
}
