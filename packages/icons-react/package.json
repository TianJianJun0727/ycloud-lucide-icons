{
  "name": "@ycloud-web/icons-react",
  "version": "0.2.2",
  "description": "A YCloud icon library package for React applications.",
  "keywords": [
    "Feather",
    "Feather Icons",
    "Font Awesome",
    "Fontawesome",
    "Icon",
    "Icons",
    "React",
    "SVG",
    "YCloud"
  ],
  "homepage": "https://tianjianjun0727.github.io/ycloud-icons/guide/react/",
  "bugs": "https://github.com/TianJianJun0727/ycloud-icons/issues",
  "license": "ISC",
  "author": "TianJianJun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TianJianJun0727/ycloud-icons.git",
    "directory": "packages/icons-react"
  },
  "files": [
    "dist",
    "dynamic.js",
    "dynamic.mjs",
    "dynamic.mjs.map",
    "dynamic.d.ts",
    "dynamicIconImports.mjs",
    "dynamicIconImports.d.ts"
  ],
  "sideEffects": false,
  "main": "dist/cjs/icons.js",
  "module": "dist/esm/icons.mjs",
  "typings": "dist/icons.d.ts",
  "exports": {
    ".": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/esm/icons.mjs",
      "require": "./dist/cjs/icons.js",
      "default": "./dist/esm/icons.mjs"
    },
    "./business": {
      "types": "./dist/business-icons.d.ts",
      "import": "./dist/esm/business-icons.mjs",
      "require": "./dist/cjs/business-icons.js",
      "default": "./dist/esm/business-icons.mjs"
    },
    "./illustration": {
      "types": "./dist/illustration-icons.d.ts",
      "import": "./dist/esm/illustration-icons.mjs",
      "require": "./dist/cjs/illustration-icons.js",
      "default": "./dist/esm/illustration-icons.mjs"
    },
    "./icons/*": {
      "import": "./dist/esm/icons/*.mjs",
      "require": "./dist/cjs/icons/*.js",
      "default": "./dist/esm/icons/*.mjs"
    },
    "./business-icons/*": {
      "import": "./dist/esm/business-icons/*.mjs",
      "require": "./dist/cjs/business-icons/*.js",
      "default": "./dist/esm/business-icons/*.mjs"
    },
    "./illustration-icons/*": {
      "import": "./dist/esm/illustration-icons/*.mjs",
      "require": "./dist/cjs/illustration-icons/*.js",
      "default": "./dist/esm/illustration-icons/*.mjs"
    },
    "./dynamic": {
      "types": "./dynamic.d.ts",
      "import": "./dynamic.mjs",
      "default": "./dynamic.mjs"
    },
    "./dynamicIconImports": {
      "types": "./dynamicIconImports.d.ts",
      "import": "./dynamicIconImports.mjs",
      "default": "./dynamicIconImports.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "pnpm clean && pnpm copy:license && pnpm build:icons && pnpm typecheck && pnpm build:bundles",
    "copy:license": "cp ../../LICENSE ./LICENSE",
    "clean": "rm -rf dist && rm -rf stats && rm -rf ./src/icons/*.ts && rm -f ./src/aliases/{prefixed,suffixed}.ts && rm -rf ./src/business-icons ./src/illustration-icons && rm -f ./src/business.ts ./src/businessTypes.ts ./src/illustration.ts ./src/illustrationTypes.ts ./src/ycloud-react.prefixed.ts ./src/ycloud-react.suffixed.ts && rm -f dynamic.{d.ts,d.mts,mts,mjs,mjs.map} && rm -f dynamicIconImports.{d.ts,d.mts,mjs,mjs.map} && rm -f business.{js,js.map,mjs,mjs.map,d.ts,d.mts} && rm -f illustration.{js,js.map,mjs,mjs.map,d.ts,d.mts}",
    "build:icons": "build-icons --output=./src --templateSrc=./scripts/exportTemplate.mts --renderUniqueKey --withAliases --withDynamicImports --aliasesFileExtension=.ts --iconFileExtension=.ts --exportFileName=index.ts && node ../../scripts/generateBusinessIconsPackage.mts react && node ../../scripts/generateIllustrationsPackage.mts react",
    "build:bundles": "NODE_OPTIONS='--require=../../scripts/useTypeScript6Register.cjs --experimental-loader=../../scripts/useTypeScript6Loader.mjs --no-warnings' rollup -c ./rollup.config.mjs",
    "typecheck": "tsc",
    "typecheck:watch": "tsc -w",
    "test": "pnpm build:icons && vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@ycloud-web/icons": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^6.0.3",
    "@ycloud-web/build-icons": "workspace:*",
    "@ycloud-web/rollup-plugins": "workspace:*",
    "@ycloud-web/shared": "workspace:*",
    "jest-serializer-html": "^7.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-preserve-directives": "^0.4.0",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.2"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "amdName": "ycloud-react"
}
