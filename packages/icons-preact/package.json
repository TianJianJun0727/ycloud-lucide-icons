{
  "name": "@ycloud-web/icons-preact",
  "version": "0.1.12",
  "description": "A YCloud icon library package for Preact applications.",
  "keywords": [
    "Feather",
    "Feather Icons",
    "Font Awesome",
    "Fontawesome",
    "Icon",
    "Icons",
    "Preact",
    "SVG",
    "YCloud"
  ],
  "homepage": "https://tianjianjun0727.github.io/ycloud-icons/guide/preact/",
  "bugs": "https://github.com/TianJianJun0727/ycloud-icons/issues",
  "license": "ISC",
  "author": "YCloud",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TianJianJun0727/ycloud-icons.git",
    "directory": "packages/icons-preact"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "dist/cjs/ycloud-preact.js",
  "module": "dist/esm/ycloud-preact.mjs",
  "typings": "dist/ycloud-preact.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ycloud-preact.d.ts",
      "import": "./dist/esm/ycloud-preact.mjs",
      "require": "./dist/cjs/ycloud-preact.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && pnpm copy:license && pnpm build:icons && pnpm build:bundles",
    "copy:license": "cp ../../LICENSE ./LICENSE",
    "clean": "rm -rf dist && rm -rf stats && rm -rf ./src/icons/*.js",
    "build:icons": "build-icons --output=./src --templateSrc=./scripts/exportTemplate.mts --renderUniqueKey --withAliases --aliasesFileExtension=.ts --iconFileExtension=.ts --exportFileName=index.ts",
    "build:bundles": "NODE_OPTIONS='--require=../../scripts/useTypeScript6Register.cjs --experimental-loader=../../scripts/useTypeScript6Loader.mjs --no-warnings' rollup -c ./rollup.config.mjs",
    "test": "pnpm build:icons && vitest run",
    "test:watch": "vitest watch"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.3",
    "@ycloud-web/build-icons": "workspace:*",
    "@ycloud-web/rollup-plugins": "workspace:*",
    "@ycloud-web/shared": "workspace:*",
    "jest-serializer-html": "^7.1.0",
    "preact": "^10.27.3",
    "rollup": "^4.62.0",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.0"
  },
  "peerDependencies": {
    "preact": "^10.27.2"
  },
  "amdName": "ycloud-preact"
}
