{
  "name": "@ycloud-web/icons-angular",
  "version": "0.1.12",
  "description": "A YCloud icon library package for Angular applications.",
  "homepage": "https://tianjianjun0727.github.io/ycloud-icons/guide/angular/",
  "bugs": "https://github.com/TianJianJun0727/ycloud-icons/issues",
  "license": "ISC",
  "author": "karsa-mistmere",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TianJianJun0727/ycloud-icons.git",
    "directory": "packages/icons-angular"
  },
  "publishConfig": {
    "directory": "dist"
  },
  "scripts": {
    "ng": "ng",
    "watch": "ng build --watch --configuration development",
    "prebuild": "pnpm clean && pnpm copy:license && pnpm build:icons",
    "build": "pnpm prebuild && pnpm build:ng",
    "copy:license": "cp ../../LICENSE ./LICENSE",
    "clean": "rm -rf dist && rm -rf ./src/icons/*.ts",
    "build:icons": "build-icons --output=./src --templateSrc=./scripts/exportTemplate.mts --renderUniqueKey --iconFileExtension=.ts --exportFileName=ycloud-angular.ts --useDefaultExports=0",
    "build:ng": "NODE_OPTIONS='--require=../../scripts/useTypeScript6Register.cjs --experimental-loader=../../scripts/useTypeScript6Loader.mjs --no-warnings' ng build --configuration production",
    "test": "pnpm build:icons && NODE_OPTIONS='--require=../../scripts/useTypeScript6Register.cjs --experimental-loader=../../scripts/useTypeScript6Loader.mjs --no-warnings' ng test --no-watch",
    "test:watch": "ng test",
    "lint": "oxlint src --quiet",
    "e2e": "ng e2e"
  },
  "devDependencies": {
    "@angular/build": "^22.0.2",
    "@angular/cli": "^22.0.2",
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/compiler-cli": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/router": "^22.0.2",
    "@vitest/browser-playwright": "^4.1.9",
    "@ycloud-web/build-icons": "workspace:*",
    "@ycloud-web/helpers": "workspace:*",
    "ng-packagr": "^22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "typescript": "7.0.1-rc"
  },
  "peerDependencies": {
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0"
  }
}
