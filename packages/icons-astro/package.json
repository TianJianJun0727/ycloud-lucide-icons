{
  "name": "@ycloud-web/icons-astro",
  "version": "0.2.2",
  "description": "A YCloud icon library package for Astro applications.",
  "keywords": [
    "Astro",
    "Feather",
    "Feather Icons",
    "Font Awesome",
    "Fontawesome",
    "Icon",
    "Icons",
    "SVG",
    "YCloud"
  ],
  "homepage": "https://tianjianjun0727.github.io/ycloud-icons/guide/astro/",
  "bugs": "https://github.com/TianJianJun0727/ycloud-icons/issues",
  "license": "ISC",
  "author": "TianJianJun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TianJianJun0727/ycloud-icons.git",
    "directory": "packages/icons-astro"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/icons.ts",
      "default": "./src/icons.ts"
    },
    "./business": {
      "import": "./src/business-icons.ts",
      "default": "./src/business-icons.ts"
    },
    "./illustration": {
      "import": "./src/illustration-icons.ts",
      "default": "./src/illustration-icons.ts"
    },
    "./icons/*": {
      "import": "./src/icons/*.ts",
      "default": "./src/icons/*.ts"
    },
    "./business-icons/*": {
      "import": "./src/business-icons/*.astro",
      "default": "./src/business-icons/*.astro"
    },
    "./illustration-icons/*": {
      "import": "./src/illustration-icons/*.astro",
      "default": "./src/illustration-icons/*.astro"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm clean && pnpm copy:license && pnpm copy:utils && pnpm build:icons",
    "build:icons": "build-icons --output=./src --templateSrc=./scripts/exportTemplate.mts --renderUniqueKey --withAliases --aliasesFileExtension=.ts --iconFileExtension=.ts --exportFileName=index.ts --pretty=false && node ../../scripts/generateBusinessIconsPackage.mts astro && node ../../scripts/generateIllustrationsPackage.mts astro",
    "clean": "rm -rf dist && rm -rf stats && rm -rf ./src/icons/*.ts && rm -rf ./src/business-icons ./src/illustration-icons && rm -f ./src/index.ts ./src/business.ts ./src/business-icons.ts ./src/businessTypes.ts ./src/illustration.ts ./src/illustration-icons.ts ./src/illustrationTypes.ts",
    "copy:license": "cp ../../LICENSE ./LICENSE",
    "copy:utils": "mkdir -p ./src/utils && for f in hasA11yProp toKebabCase mergeClasses; do cp -f ../../packages/icons-shared/src/utils/$f.ts ./src/utils/; done",
    "test": "pnpm copy:utils && pnpm build:icons && vitest run",
    "test:watch": "pnpm build:icons && vitest run --watch"
  },
  "dependencies": {
    "@ycloud-web/icons": "workspace:*"
  },
  "devDependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/ts-plugin": "^1.10.9",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@ycloud-web/build-icons": "workspace:*",
    "astro": "^6.4.8",
    "jest-serializer-html": "^7.1.0",
    "linkedom": "^0.18.5",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.0",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "astro": "^4 || ^5 || ^6 || ^7"
  }
}
