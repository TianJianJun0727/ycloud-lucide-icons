{
  "name": "@ycloud-web/icons-solid",
  "version": "0.2.2",
  "description": "A YCloud icon library package for Solid applications.",
  "keywords": [
    "Feather",
    "Feather Icons",
    "Font Awesome",
    "Fontawesome",
    "Icon",
    "Icons",
    "SVG",
    "Solid",
    "SolidJS",
    "YCloud"
  ],
  "homepage": "https://tianjianjun0727.github.io/ycloud-icons/guide/solid/",
  "bugs": "https://github.com/TianJianJun0727/ycloud-icons/issues",
  "license": "ISC",
  "author": "TianJianJun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TianJianJun0727/ycloud-icons.git",
    "directory": "packages/icons-solid"
  },
  "source": "src/ycloud-solid.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "dist/cjs/icons.js",
  "module": "dist/esm/icons.mjs",
  "types": "dist/types/icons.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/icons.d.ts",
      "solid": "./dist/source/icons.jsx",
      "import": "./dist/esm/icons.mjs",
      "browser": "./dist/esm/icons.mjs",
      "require": "./dist/cjs/icons.js",
      "default": "./dist/esm/icons.mjs"
    },
    "./business": {
      "types": "./dist/types/business-icons.d.ts",
      "solid": "./dist/source/business-icons.jsx",
      "import": "./dist/esm/business-icons.mjs",
      "browser": "./dist/esm/business-icons.mjs",
      "require": "./dist/cjs/business-icons.js",
      "default": "./dist/esm/business-icons.mjs"
    },
    "./illustration": {
      "types": "./dist/types/illustration-icons.d.ts",
      "solid": "./dist/source/illustration-icons.jsx",
      "import": "./dist/esm/illustration-icons.mjs",
      "browser": "./dist/esm/illustration-icons.mjs",
      "require": "./dist/cjs/illustration-icons.js",
      "default": "./dist/esm/illustration-icons.mjs"
    },
    "./icons/*": {
      "types": "./dist/types/icons/*.d.ts",
      "solid": "./dist/source/icons/*.jsx",
      "import": "./dist/esm/icons/*.mjs",
      "browser": "./dist/esm/icons/*.mjs",
      "require": "./dist/cjs/icons/*.js",
      "default": "./dist/esm/icons/*.mjs"
    },
    "./business-icons/*": {
      "types": "./dist/types/business-icons/*.d.ts",
      "solid": "./dist/source/business-icons/*.jsx",
      "import": "./dist/esm/business-icons/*.mjs",
      "browser": "./dist/esm/business-icons/*.mjs",
      "require": "./dist/cjs/business-icons/*.js",
      "default": "./dist/esm/business-icons/*.mjs"
    },
    "./illustration-icons/*": {
      "types": "./dist/types/illustration-icons/*.d.ts",
      "solid": "./dist/source/illustration-icons/*.jsx",
      "import": "./dist/esm/illustration-icons/*.mjs",
      "browser": "./dist/esm/illustration-icons/*.mjs",
      "require": "./dist/cjs/illustration-icons/*.js",
      "default": "./dist/esm/illustration-icons/*.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm clean && pnpm copy:license && pnpm build:icons && pnpm build:bundle",
    "copy:license": "cp ../../LICENSE ./LICENSE",
    "clean": "rm -rf dist && rm -rf stats && rm -rf ./src/icons/*.ts && rm -f ./src/aliases/{prefixed,suffixed}.ts && rm -rf ./src/business-icons ./src/illustration-icons && rm -f ./src/business.ts ./src/businessTypes.ts ./src/illustration.ts ./src/illustrationTypes.ts",
    "build:transpile": "tsc --jsx preserve -t es2020 --rootDir src --outDir dist --noEmit false",
    "build:version": "node ./scripts/replaceVersion.mjs",
    "build:bundle": "NODE_OPTIONS='--require=../../scripts/useTypeScript6Register.cjs --experimental-loader=../../scripts/useTypeScript6Loader.mjs --no-warnings' rollup -c rollup.config.mjs",
    "build:icons": "build-icons --output=./src --templateSrc=./scripts/exportTemplate.mts --renderUniqueKey --withAliases --aliasesFileExtension=.ts --iconFileExtension=.tsx --exportFileName=index.ts && node ../../scripts/generateBusinessIconsPackage.mts solid && node ../../scripts/generateIllustrationsPackage.mts solid",
    "typecheck": "tsc",
    "typecheck:watch": "tsc -w",
    "test": "pnpm build:icons && vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@ycloud-web/icons": "workspace:*"
  },
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/preset-env": "^7.23.9",
    "@babel/preset-typescript": "^7.23.3",
    "@rollup/plugin-babel": "^7.1.0",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@ycloud-web/build-icons": "workspace:*",
    "@ycloud-web/rollup-plugins": "workspace:*",
    "@ycloud-web/shared": "workspace:*",
    "babel-preset-solid": "^1.8.12",
    "esbuild": "^0.28.1",
    "jest-serializer-html": "^7.1.0",
    "rollup": "^4.62.0",
    "solid-js": "^1.9.4",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.0",
    "vite-plugin-solid": "^2.11.12"
  },
  "peerDependencies": {
    "solid-js": "^1.4.7"
  }
}
