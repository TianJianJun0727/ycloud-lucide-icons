{
  "name": "@ycloud-web/icons-vue",
  "version": "0.2.1",
  "description": "A YCloud icon library package for Vue applications.",
  "keywords": [
    "Feather",
    "Feather Icons",
    "Icon",
    "Icons",
    "SVG",
    "Vue",
    "YCloud"
  ],
  "homepage": "https://tianjianjun0727.github.io/ycloud-icons/guide/vue/",
  "bugs": "https://github.com/TianJianJun0727/ycloud-icons/issues",
  "license": "ISC",
  "author": "TianJianJun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TianJianJun0727/ycloud-icons.git",
    "directory": "packages/icons-vue"
  },
  "source": "build/ycloud-vue.js",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "dist/cjs/icons.js",
  "module": "dist/esm/icons.mjs",
  "typings": "dist/icons.d.ts",
  "exports": {
    ".": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/esm/icons.mjs",
      "require": "./dist/cjs/icons.js",
      "default": "./dist/esm/icons.mjs"
    },
    "./business": {
      "types": "./dist/business-icons.d.ts",
      "import": "./dist/esm/business-icons.mjs",
      "require": "./dist/cjs/business-icons.js",
      "default": "./dist/esm/business-icons.mjs"
    },
    "./illustration": {
      "types": "./dist/illustration-icons.d.ts",
      "import": "./dist/esm/illustration-icons.mjs",
      "require": "./dist/cjs/illustration-icons.js",
      "default": "./dist/esm/illustration-icons.mjs"
    },
    "./icons/*": {
      "import": "./dist/esm/icons/*.mjs",
      "require": "./dist/cjs/icons/*.js",
      "default": "./dist/esm/icons/*.mjs"
    },
    "./business-icons/*": {
      "import": "./dist/esm/business-icons/*.mjs",
      "require": "./dist/cjs/business-icons/*.js",
      "default": "./dist/esm/business-icons/*.mjs"
    },
    "./illustration-icons/*": {
      "import": "./dist/esm/illustration-icons/*.mjs",
      "require": "./dist/cjs/illustration-icons/*.js",
      "default": "./dist/esm/illustration-icons/*.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "pnpm clean && pnpm copy:license && pnpm build:icons && pnpm build:bundles",
    "copy:license": "cp ../../LICENSE ./LICENSE",
    "clean": "rm -rf dist && rm -rf stats && rm -rf ./src/icons/*.ts && rm -f ./src/aliases/{prefixed,suffixed}.ts && rm -rf ./src/business-icons ./src/illustration-icons && rm -f ./src/business.ts ./src/businessTypes.ts ./src/illustration.ts ./src/illustrationTypes.ts ./src/ycloud-vue.prefixed.ts ./src/ycloud-vue.suffixed.ts",
    "build:icons": "build-icons --output=./src --templateSrc=./scripts/exportTemplate.mts --renderUniqueKey --withAliases --aliasesFileExtension=.ts --iconFileExtension=.ts --exportFileName=index.ts && node ../../scripts/generateBusinessIconsPackage.mts vue && node ../../scripts/generateIllustrationsPackage.mts vue",
    "build:bundles": "NODE_OPTIONS='--require=../../scripts/useTypeScript6Register.cjs --experimental-loader=../../scripts/useTypeScript6Loader.mjs --no-warnings' rollup -c ./rollup.config.mjs",
    "typecheck": "tsc",
    "typecheck:watch": "tsc -w",
    "test": "pnpm build:icons && vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@ycloud-web/icons": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "2.4.11",
    "@ycloud-web/build-icons": "workspace:*",
    "@ycloud-web/rollup-plugins": "workspace:*",
    "@ycloud-web/shared": "workspace:*",
    "rollup": "^4.62.0",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.0",
    "vue": "^3.4.21"
  },
  "peerDependencies": {
    "vue": ">=3.0.1"
  },
  "amdName": "ycloud-vue"
}
