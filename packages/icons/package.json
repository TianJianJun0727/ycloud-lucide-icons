{
  "name": "@ycloud-web/icons",
  "version": "0.2.1",
  "description": "A YCloud icon library package for web and JavaScript applications.",
  "keywords": [
    "Feather",
    "Feather Icons",
    "Font Awesome",
    "Fontawesome",
    "HTML",
    "Icon",
    "Icons",
    "SVG",
    "YCloud"
  ],
  "homepage": "https://tianjianjun0727.github.io/ycloud-icons/guide/ycloud/",
  "bugs": "https://github.com/TianJianJun0727/ycloud-icons/issues",
  "license": "ISC",
  "author": "TianJianJun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TianJianJun0727/ycloud-icons.git",
    "directory": "packages/icons"
  },
  "source": "src/ycloud.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "dist/cjs/icons.js",
  "module": "dist/esm/icons.mjs",
  "typings": "dist/icons.d.ts",
  "unpkg": "dist/umd/icons.min.js",
  "exports": {
    ".": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/esm/icons.mjs",
      "require": "./dist/cjs/icons.js",
      "default": "./dist/esm/icons.mjs"
    },
    "./business": {
      "types": "./dist/business-icons.d.ts",
      "import": "./dist/esm/business-icons.mjs",
      "require": "./dist/cjs/business-icons.js",
      "default": "./dist/esm/business-icons.mjs"
    },
    "./illustration": {
      "types": "./dist/illustration-icons.d.ts",
      "import": "./dist/esm/illustration-icons.mjs",
      "require": "./dist/cjs/illustration-icons.js",
      "default": "./dist/esm/illustration-icons.mjs"
    },
    "./icons/*.svg": null,
    "./icons/*/*.svg": null,
    "./icons/*": {
      "import": "./dist/esm/icons/*.mjs",
      "require": "./dist/cjs/icons/*.js",
      "default": "./dist/esm/icons/*.mjs"
    },
    "./business-icons/*.svg": null,
    "./business-icons/*/*.svg": null,
    "./business-icons/*": {
      "import": "./dist/esm/business-icons/*.mjs",
      "require": "./dist/cjs/business-icons/*.js",
      "default": "./dist/esm/business-icons/*.mjs"
    },
    "./illustration-icons/*.svg": null,
    "./illustration-icons/*/*.svg": null,
    "./illustration-icons/*": {
      "import": "./dist/esm/illustration-icons/*.mjs",
      "require": "./dist/cjs/illustration-icons/*.js",
      "default": "./dist/esm/illustration-icons/*.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "pnpm clean && pnpm copy:license && pnpm build:icons && pnpm build:bundle",
    "copy:license": "cp ../../LICENSE ./LICENSE",
    "clean": "rm -rf dist && rm -rf stats && rm -rf ./src/icons/*.ts && rm -rf ./src/illustration-icons && rm -f ./src/illustration.ts ./src/illustrationTypes.ts",
    "build:icons": "build-icons --output=./src --templateSrc=./scripts/exportTemplate.mts --iconFileExtension=.ts --withAliases --aliasesFileExtension=.ts --exportFileName=index.ts && node ../../scripts/generateBusinessIconsPackage.mts core && node ../../scripts/generateIllustrationsPackage.mts core",
    "build:bundle": "NODE_OPTIONS='--require=../../scripts/useTypeScript6Register.cjs --experimental-loader=../../scripts/useTypeScript6Loader.mjs --no-warnings' rollup -c rollup.config.mjs",
    "test": "pnpm build:icons && vitest run",
    "test:watch": "vitest watch"
  },
  "devDependencies": {
    "@rollup/plugin-replace": "^6.0.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@ycloud-web/build-icons": "workspace:*",
    "@ycloud-web/rollup-plugins": "workspace:*",
    "@ycloud-web/shared": "workspace:*",
    "jest-serializer-html": "^7.1.0",
    "rollup": "^4.62.0",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.0"
  },
  "amdName": "ycloud",
  "main:umd": "dist/umd/icons.js"
}
