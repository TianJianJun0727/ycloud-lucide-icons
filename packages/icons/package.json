{
  "name": "@ycloud-web/icons-data",
  "description": "A YCloud icon data package that contains normalized icon nodes and metadata.",
  "version": "0.1.2",
  "license": "ISC",
  "homepage": "https://github.com/TianJianJun0727/ycloud-icons",
  "bugs": "https://github.com/TianJianJun0727/ycloud-icons/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TianJianJun0727/ycloud-icons.git",
    "directory": "packages/icons"
  },
  "keywords": [
    "YCloud",
    "HTML",
    "Feather",
    "Icons",
    "Icon",
    "SVG",
    "Feather Icons"
  ],
  "amdName": "ycloud-icons",
  "source": "src/ycloud-icons.ts",
  "main": "dist/cjs/ycloud-icons.cjs",
  "module": "dist/esm/ycloud-icons.mjs",
  "types": "dist/esm/ycloud-icons.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/esm/ycloud-icons.d.ts",
      "import": "./dist/esm/ycloud-icons.mjs",
      "require": "./dist/cjs/ycloud-icons.cjs",
      "default": "./dist/esm/ycloud-icons.mjs"
    },
    "./icons/*": {
      "import": "./dist/esm/icons/*.mjs",
      "default": "./dist/esm/icons/*.mjs"
    },
    "./dynamic": {
      "types": "./dist/esm/dynamic.d.ts",
      "import": "./dist/esm/dynamic.mjs",
      "require": "./dist/cjs/dynamic.cjs",
      "default": "./dist/esm/dynamic.mjs"
    },
    "./build": {
      "types": "./dist/esm/build.d.ts",
      "import": "./dist/esm/build.mjs",
      "require": "./dist/cjs/build.cjs",
      "default": "./dist/esm/build.mjs"
    }
  },
  "scripts": {
    "build": "pnpm clean && pnpm copy:license && pnpm build:icons && pnpm build:bundle",
    "copy:license": "cp ../../LICENSE ./LICENSE",
    "clean": "rm -rf dist && rm -rf stats && rm -rf ./src/icons/*.ts",
    "build:icons": "build-icons --output=./src --templateSrc=./scripts/exportTemplate.mjs --renderUniqueKey --withAliases --withDynamicImports --separateAliasesFile --aliasesFileExtension=.ts --iconFileExtension=.ts --exportFileName=index.ts",
    "build:bundle": "rollup -c rollup.config.mjs",
    "test": "pnpm build:icons && vitest run",
    "test:watch": "vitest watch",
    "test:update": "vitest -u"
  },
  "devDependencies": {
    "@rollup/plugin-replace": "^6.0.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@ycloud-web/build-icons": "workspace:*",
    "@ycloud-web/helpers": "workspace:*",
    "@ycloud-web/rollup-plugins": "workspace:*",
    "jest-serializer-html": "^7.1.0",
    "rollup": "^4.62.0",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-preserve-directives": "^0.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "4.1.9"
  }
}
