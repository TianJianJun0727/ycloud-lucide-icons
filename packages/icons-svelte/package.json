{
  "name": "@ycloud-web/icons-svelte",
  "version": "0.1.12",
  "description": "A YCloud icon library package for Svelte applications.",
  "keywords": [
    "Feather",
    "Feather Icons",
    "Font Awesome",
    "Fontawesome",
    "Icon",
    "Icons",
    "SVG",
    "Svelte",
    "YCloud"
  ],
  "homepage": "https://tianjianjun0727.github.io/ycloud-icons/guide/svelte/",
  "bugs": "https://github.com/TianJianJun0727/ycloud-icons/issues",
  "license": "ISC",
  "author": "YCloud",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TianJianJun0727/ycloud-icons.git",
    "directory": "packages/icons-svelte"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/ycloud-svelte.js",
  "typings": "dist/ycloud-svelte.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ycloud-svelte.d.ts",
      "svelte": "./dist/ycloud-svelte.js",
      "default": "./dist/ycloud-svelte.js"
    },
    "./icons": {
      "types": "./dist/ycloud-svelte.d.ts",
      "svelte": "./dist/ycloud-svelte.js"
    },
    "./icons/*": {
      "types": "./dist/icons/*.svelte.d.ts",
      "svelte": "./dist/icons/*.js",
      "default": "./dist/icons/*.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && pnpm copy:license && pnpm copy:utils && pnpm build:icons && pnpm build:package && pnpm build:license",
    "copy:license": "cp ../../LICENSE ./LICENSE",
    "copy:utils": "mkdir -p ./src/utils && cp -rf ../../packages/icons-shared/src/utils/hasA11yProp.ts ./src/utils/",
    "clean": "rm -rf dist stats ./src/icons/*.{ts,svelte} ./src/aliases/{aliases,prefixed,suffixed}.ts",
    "build:icons": "build-icons --output=./src --templateSrc=./scripts/exportTemplate.mts --exportFileName=index.ts --iconFileExtension=.svelte --importImportFileExtension=.svelte --separateIconFileExport --separateIconFileExportExtension=.ts --withAliases --aliasesFileExtension=.ts --separateAliasesFile  --separateAliasesFileExtension=.ts --aliasImportFileExtension=.js --pretty=false",
    "build:package": "NODE_OPTIONS='--require=../../scripts/useTypeScript6Register.cjs --experimental-loader=../../scripts/useTypeScript6Loader.mjs --no-warnings' svelte-package --input ./src",
    "build:license": "node ./scripts/appendBlockComments.mts",
    "test": "pnpm copy:license && pnpm copy:utils && pnpm build:icons && vitest run",
    "test:watch": "vitest watch",
    "typecheck": "pnpm copy:license && pnpm copy:utils && pnpm build:icons && svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.4",
    "@ycloud-web/build-icons": "workspace:*",
    "@ycloud-web/helpers": "workspace:*",
    "jest-serializer-html": "^7.1.0",
    "jsdom": "^29.1.1",
    "svelte": "^5.38.6",
    "svelte-check": "^4.3.4",
    "svelte-preprocess": "^6.0.3",
    "typescript": "npm:@typescript/typescript6@6.0.1",
    "vite": "^8.1.0",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "svelte": "^5"
  }
}
