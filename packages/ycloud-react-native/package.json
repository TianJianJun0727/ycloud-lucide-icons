{
  "name": "@ycloud-web/icons-react-native",
  "description": "A YCloud icon library package for React Native applications.",
  "version": "0.1.2",
  "license": "ISC",
  "homepage": "https://github.com/TianJianJun0727/ycloud-icons",
  "bugs": "https://github.com/TianJianJun0727/ycloud-icons/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TianJianJun0727/ycloud-icons.git",
    "directory": "packages/ycloud-react-native"
  },
  "keywords": [
    "YCloud",
    "React Native",
    "Feather",
    "Icons",
    "Icon",
    "SVG",
    "Feather Icons",
    "Fontawesome",
    "Font Awesome"
  ],
  "author": "YCloud",
  "amdName": "ycloud-react-native",
  "main": "dist/cjs/ycloud-react-native.js",
  "module": "dist/esm/ycloud-react-native.mjs",
  "typings": "dist/ycloud-react-native.d.ts",
  "react-native": "dist/esm/ycloud-react-native.mjs",
  "exports": {
    ".": {
      "types": "./dist/ycloud-react-native.d.ts",
      "import": "./dist/esm/ycloud-react-native.mjs",
      "browser": "./dist/esm/ycloud-react-native.mjs",
      "require": "./dist/cjs/ycloud-react-native.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/esm/icons/index.mjs",
      "browser": "./dist/esm/icons/index.mjs",
      "require": "./dist/cjs/icons/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm copy:license && pnpm build:icons && pnpm build:bundles",
    "copy:license": "cp ../../LICENSE ./LICENSE",
    "clean": "rm -rf dist && rm -rf stats && rm -rf ./src/icons/*.ts",
    "build:icons": "build-icons --output=./src --templateSrc=./scripts/exportTemplate.mts --renderUniqueKey --iconFileExtension=.ts --exportFileName=index.ts --withAliases --aliasesFileExtension=.ts",
    "build:bundles": "rollup -c ./rollup.config.mjs",
    "test": "pnpm build:icons && vitest run",
    "test:watch": "vitest watch"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/prop-types": "^15.7.5",
    "@types/react": "^18.0.21",
    "@vitejs/plugin-react": "^6.0.2",
    "@ycloud-web/build-icons": "workspace:*",
    "@ycloud-web/rollup-plugins": "workspace:*",
    "@ycloud-web/shared": "workspace:*",
    "jest-serializer-html": "^7.1.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-native": "^0.76.0",
    "react-native-svg": "^15.8.0",
    "rollup": "^4.62.0",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "peerDependencies": {
    "react": "^16.5.1 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-native": "*",
    "react-native-svg": "^12.0.0 || ^13.0.0 || ^14.0.0 || ^15.0.0"
  }
}
