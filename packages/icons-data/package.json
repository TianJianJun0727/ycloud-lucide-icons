{
  "name": "@ycloud-web/icons-data",
  "version": "0.2.2",
  "description": "A YCloud icon data package that contains normalized icon nodes and metadata.",
  "keywords": [
    "Feather",
    "Feather Icons",
    "HTML",
    "Icon",
    "Icons",
    "SVG",
    "YCloud"
  ],
  "homepage": "https://tianjianjun0727.github.io/ycloud-icons/guide/packages/icons-data/",
  "bugs": "https://github.com/TianJianJun0727/ycloud-icons/issues",
  "license": "ISC",
  "author": "TianJianJun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TianJianJun0727/ycloud-icons.git",
    "directory": "packages/icons-data"
  },
  "source": "src/ycloud-icons.ts",
  "sideEffects": false,
  "main": "dist/cjs/icons.cjs",
  "module": "dist/esm/icons.mjs",
  "types": "dist/esm/icons.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/icons.d.ts",
      "import": "./dist/esm/icons.mjs",
      "require": "./dist/cjs/icons.cjs",
      "default": "./dist/esm/icons.mjs"
    },
    "./business": {
      "types": "./dist/esm/business-icons.d.ts",
      "import": "./dist/esm/business-icons.mjs",
      "require": "./dist/cjs/business-icons.cjs",
      "default": "./dist/esm/business-icons.mjs"
    },
    "./illustration": {
      "types": "./dist/esm/illustration-icons.d.ts",
      "import": "./dist/esm/illustration-icons.mjs",
      "require": "./dist/cjs/illustration-icons.cjs",
      "default": "./dist/esm/illustration-icons.mjs"
    },
    "./icons/*.svg": null,
    "./icons/*/*.svg": null,
    "./icons/*": {
      "import": "./dist/esm/icons/*.mjs",
      "require": "./dist/cjs/icons/*.cjs",
      "default": "./dist/esm/icons/*.mjs"
    },
    "./business-icons/*.svg": null,
    "./business-icons/*/*.svg": null,
    "./business-icons/*": {
      "import": "./dist/esm/business-icons/*.mjs",
      "require": "./dist/cjs/business-icons/*.cjs",
      "default": "./dist/esm/business-icons/*.mjs"
    },
    "./illustration-icons/*.svg": null,
    "./illustration-icons/*/*.svg": null,
    "./illustration-icons/*": {
      "import": "./dist/esm/illustration-icons/*.mjs",
      "require": "./dist/cjs/illustration-icons/*.cjs",
      "default": "./dist/esm/illustration-icons/*.mjs"
    },
    "./dynamic": {
      "types": "./dist/esm/dynamic.d.ts",
      "import": "./dist/esm/dynamic.mjs",
      "require": "./dist/cjs/dynamic.cjs",
      "default": "./dist/esm/dynamic.mjs"
    },
    "./build": {
      "types": "./dist/esm/build.d.ts",
      "import": "./dist/esm/build.mjs",
      "require": "./dist/cjs/build.cjs",
      "default": "./dist/esm/build.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "pnpm clean && pnpm copy:license && pnpm build:icons && pnpm build:bundle",
    "copy:license": "cp ../../LICENSE ./LICENSE",
    "clean": "rm -rf dist && rm -rf stats && rm -rf ./src/icons/*.ts && rm -f ./src/aliases/{prefixed,suffixed}.ts && rm -rf ./src/business-icons && rm -f ./src/business.ts && rm -rf ./src/illustration-icons && rm -f ./src/illustration.ts ./src/illustrationTypes.ts ./src/ycloud-icons.prefixed.ts ./src/ycloud-icons.suffixed.ts",
    "build:icons": "build-icons --output=./src --templateSrc=./scripts/exportTemplate.mjs --renderUniqueKey --withAliases --withDynamicImports --aliasesFileExtension=.ts --iconFileExtension=.ts --exportFileName=index.ts && node ../../scripts/generateBusinessIconsPackage.mts data && node ../../scripts/generateIllustrationsPackage.mts data",
    "build:bundle": "NODE_OPTIONS='--require=../../scripts/useTypeScript6Register.cjs --experimental-loader=../../scripts/useTypeScript6Loader.mjs --no-warnings' rollup -c rollup.config.mjs",
    "test": "pnpm build:icons && vitest run",
    "test:watch": "vitest watch",
    "test:update": "vitest -u"
  },
  "devDependencies": {
    "@rollup/plugin-replace": "^6.0.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@ycloud-web/build-icons": "workspace:*",
    "@ycloud-web/helpers": "workspace:*",
    "@ycloud-web/rollup-plugins": "workspace:*",
    "jest-serializer-html": "^7.1.0",
    "rollup": "^4.62.0",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-preserve-directives": "^0.4.0",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.0",
    "vitest": "4.1.9"
  },
  "amdName": "ycloud-icons"
}
