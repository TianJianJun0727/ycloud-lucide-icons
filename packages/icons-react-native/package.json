{
  "name": "@ycloud-web/icons-react-native",
  "version": "0.2.1",
  "description": "A YCloud icon library package for React Native applications.",
  "keywords": [
    "Feather",
    "Feather Icons",
    "Font Awesome",
    "Fontawesome",
    "Icon",
    "Icons",
    "React Native",
    "SVG",
    "YCloud"
  ],
  "homepage": "https://tianjianjun0727.github.io/ycloud-icons/guide/react-native/",
  "bugs": "https://github.com/TianJianJun0727/ycloud-icons/issues",
  "license": "ISC",
  "author": "TianJianJun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TianJianJun0727/ycloud-icons.git",
    "directory": "packages/icons-react-native"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "dist/cjs/icons.js",
  "module": "dist/esm/icons.mjs",
  "typings": "dist/icons.d.ts",
  "react-native": "dist/esm/icons.mjs",
  "exports": {
    ".": {
      "types": "./dist/icons.d.ts",
      "browser": "./dist/esm/icons.mjs",
      "import": "./dist/esm/icons.mjs",
      "require": "./dist/cjs/icons.js",
      "default": "./dist/esm/icons.mjs"
    },
    "./business": {
      "types": "./dist/business-icons.d.ts",
      "browser": "./dist/esm/business-icons.mjs",
      "import": "./dist/esm/business-icons.mjs",
      "require": "./dist/cjs/business-icons.js",
      "default": "./dist/esm/business-icons.mjs"
    },
    "./illustration": {
      "types": "./dist/illustration-icons.d.ts",
      "browser": "./dist/esm/illustration-icons.mjs",
      "import": "./dist/esm/illustration-icons.mjs",
      "require": "./dist/cjs/illustration-icons.js",
      "default": "./dist/esm/illustration-icons.mjs"
    },
    "./icons/*": {
      "browser": "./dist/esm/icons/*.mjs",
      "import": "./dist/esm/icons/*.mjs",
      "require": "./dist/cjs/icons/*.js",
      "default": "./dist/esm/icons/*.mjs"
    },
    "./business-icons/*": {
      "browser": "./dist/esm/business-icons/*.mjs",
      "import": "./dist/esm/business-icons/*.mjs",
      "require": "./dist/cjs/business-icons/*.js",
      "default": "./dist/esm/business-icons/*.mjs"
    },
    "./illustration-icons/*": {
      "browser": "./dist/esm/illustration-icons/*.mjs",
      "import": "./dist/esm/illustration-icons/*.mjs",
      "require": "./dist/cjs/illustration-icons/*.js",
      "default": "./dist/esm/illustration-icons/*.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm clean && pnpm copy:license && pnpm build:icons && pnpm build:bundles",
    "copy:license": "cp ../../LICENSE ./LICENSE",
    "clean": "rm -rf dist && rm -rf stats && rm -rf ./src/icons/*.ts && rm -f ./src/aliases/{prefixed,suffixed}.ts && rm -rf ./src/business-icons ./src/illustration-icons && rm -f ./src/business.ts ./src/businessTypes.ts ./src/illustration.ts ./src/illustrationTypes.ts ./src/ycloud-react-native.prefixed.ts ./src/ycloud-react-native.suffixed.ts",
    "build:icons": "build-icons --output=./src --templateSrc=./scripts/exportTemplate.mts --renderUniqueKey --iconFileExtension=.ts --exportFileName=index.ts --withAliases --aliasesFileExtension=.ts && node ../../scripts/generateBusinessIconsPackage.mts react-native && node ../../scripts/generateIllustrationsPackage.mts react-native",
    "build:bundles": "NODE_OPTIONS='--require=../../scripts/useTypeScript6Register.cjs --experimental-loader=../../scripts/useTypeScript6Loader.mjs --no-warnings' rollup -c ./rollup.config.mjs",
    "test": "pnpm build:icons && vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@ycloud-web/icons": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/prop-types": "^15.7.5",
    "@types/react": "^18.0.21",
    "@vitejs/plugin-react": "^6.0.3",
    "@ycloud-web/build-icons": "workspace:*",
    "@ycloud-web/rollup-plugins": "workspace:*",
    "@ycloud-web/shared": "workspace:*",
    "jest-serializer-html": "^7.1.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-native": "^0.76.0",
    "react-native-svg": "^15.8.0",
    "rollup": "^4.62.0",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.0"
  },
  "peerDependencies": {
    "react": "^16.5.1 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-native": "*",
    "react-native-svg": "^12.0.0 || ^13.0.0 || ^14.0.0 || ^15.0.0"
  },
  "amdName": "ycloud-react-native"
}
