{
  "private": true,
  "scripts": {
    "build": "pnpm -r --filter './packages/**' build",
    "test": "pnpm -r --filter './packages/**' test",
    "test:update": "pnpm -r --filter './packages/**' --filter !'@ycloud-web/icons-angular' test -- -u",
    "test:font": "pnpm --filter build-font test",
    "icons": "pnpm --filter @ycloud-web/icons",
    "icons-react": "pnpm --filter @ycloud-web/icons-react",
    "icons-vue": "pnpm --filter @ycloud-web/icons-vue",
    "icons-angular": "pnpm --filter @ycloud-web/icons-angular",
    "icons-react-native": "pnpm --filter @ycloud-web/icons-react-native",
    "icons-preact": "pnpm --filter @ycloud-web/icons-preact",
    "icons-solid": "pnpm --filter @ycloud-web/icons-solid",
    "icons-astro": "pnpm --filter @ycloud-web/icons-astro",
    "icons-svelte": "pnpm --filter @ycloud-web/icons-svelte",
    "icons-static": "pnpm --filter @ycloud-web/icons-static",
    "figma": "pnpm --filter @ycloud-web/figma-plugin",
    "figma:dev": "pnpm --filter @ycloud-web/figma-plugin dev",
    "figma:build": "pnpm --filter @ycloud-web/figma-plugin build",
    "figma:typecheck": "pnpm --filter @ycloud-web/figma-plugin typecheck",
    "docs:dev": "pnpm --filter @ycloud-web/icons-docs docs:dev",
    "docs:dev:og": "pnpm --filter @ycloud-web/icons-docs docs:dev:og",
    "docs:dev:no-og": "pnpm --filter @ycloud-web/icons-docs docs:dev:no-og",
    "docs:build": "pnpm --filter @ycloud-web/icons-docs docs:build",
    "docs:build:github-pages": "NODE_OPTIONS=--max-old-space-size=12288 pnpm --dir docs docs:build:github-pages",
    "docs:build:og": "pnpm --filter @ycloud-web/icons-docs docs:build:og",
    "docs:build:no-og": "pnpm --filter @ycloud-web/icons-docs docs:build:no-og",
    "build:outline-icons": "pnpm --filter outline-svg start",
    "build:font": "pnpm --filter build-font start",
    "optimize": "node ./scripts/optimizeSvgs.mts",
    "addjsons": "node ./scripts/addMissingIconMetadataFiles.mts",
    "addcategoryjsons": "node ./scripts/addMissingCategoryMetadataFiles.mts",
    "checkIcons": "node ./scripts/checkIconsAndCategories.mts",
    "generate:changelog": "node ./scripts/writeChangelog.mts",
    "generate:changelog:md": "node ./scripts/writeChangelog.mts",
    "sync:github-release-notes": "node ./scripts/syncGitHubReleaseNotes.mts",
    "sync:package-versions": "node ./scripts/syncPackageVersions.mts",
    "optimize:business": "node ./scripts/optimizeBusinessSvgs.mts",
    "generate:business-index": "node ./scripts/writeBusinessIconIndex.mts",
    "generate:sponsors": "node scripts/updateSponsors.mts",
    "generate:nextJSAliases": "node ./scripts/generateNextJSAliases.mts",
    "polish:tags": "node ./scripts/polishIconTagsByCategory.mts",
    "suggest:metadata": "node ./scripts/suggestIconMetadata.mts",
    "suggest:metadata:watch": "node --env-file .env --watch ./scripts/suggestIconMetadata.mts",
    "postinstall": "husky install",
    "lint:es": "oxlint . --quiet",
    "lint:format": "oxfmt --check '**/*.{js,mjs,ts,jsx,tsx,html,css,scss,json,yml,yaml}' --ignore-path .oxfmtignore --no-error-on-unmatched-pattern",
    "lint:format-fix": "oxfmt '**/*.{js,mjs,ts,jsx,tsx,html,css,scss,json,yml,yaml}' --ignore-path .oxfmtignore --no-error-on-unmatched-pattern",
    "lint:svg:icons": "node ./scripts/checkSvgSource.mts && prettier --parser html --check 'icons/*.svg'",
    "lint:svg:business": "node ./scripts/checkBusinessSvgSource.mts",
    "lint:svg": "pnpm lint:svg:icons && pnpm lint:svg:business",
    "lint:json:icons": "ajv --spec=draft2020 -s icon.schema.json -d 'icons/*.json' > /dev/null",
    "lint:json:categories": "ajv --spec=draft2020 -s category.schema.json -d 'categories/*.json' > /dev/null",
    "lint:json": "pnpm run lint:json:icons && pnpm run lint:json:categories",
    "lint": "pnpm lint:es && pnpm lint:format && pnpm lint:svg && pnpm lint:json",
    "format": "pnpm lint:format-fix",
    "format:svg": "prettier --parser html --write 'icons/*.svg'",
    "prepare": "husky install",
    "gi": "node ./scripts/generate/generateIcons.mts",
    "rename": "node ./scripts/rename/renameIcon.mts",
    "renamePattern": "node ./scripts/rename/renamePattern.mts"
  },
  "devDependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "@ai-sdk/openai": "3.0.73",
    "@octokit/rest": "^19.0.13",
    "@types/node": "^24.13.2",
    "@types/yargs": "^17.0.35",
    "@typescript/typescript6": "6.0.1",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "4.1.9",
    "ai": "6.0.208",
    "ajv-cli": "^5.0.0",
    "dotenv": "^17.4.2",
    "husky": "^8.0.3",
    "jsdom": "^29.1.1",
    "lint-staged": "^13.3.0",
    "minimist": "^1.2.8",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "p-memoize": "^7.1.1",
    "prettier": "^3.8.4",
    "semver": "^7.8.0",
    "simple-git": "^3.36.0",
    "svgo": "^3.3.3",
    "svgson": "^5.3.1",
    "typescript": "7.0.1-rc",
    "vitest": "4.1.9",
    "yargs": "^17.7.2",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">=24.11.1"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
